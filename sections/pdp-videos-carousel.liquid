<link rel="stylesheet" href="{{ 'pdp-videos-carousel.css' | asset_url }}">
<div class="section pdp-videos-carousel-container">
  <p class="section-heading">{{ section.settings.section_heading }}</p>
  <div class="pdp-videos-carousel-wrapper">
    {% for block in section.blocks %}
      <div class="pdp-videos-carousel-video">
        <video src="{{ block.settings.video_url | video_url }}"></video>
        <p class="pdp-videos-carousel-content-heading">{{ block.settings.video_heading }}</p>
        <p class="pdp-videos-carousel-content-subheading">{{ block.settings.video_subheading }}</p>
      </div>
    {% endfor %}
  </div>
</div>
{% schema %}
{
  "name": "Videos Carousel PDP",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "video",
          "id": "video_url",
          "label": "Video"
        },
        {
          "type": "text",
          "id": "video_heading",
          "label": "Video Heading"
        },
        {
          "type": "textarea",
          "id": "video_subheading",
          "label": "Video Subheading"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Videos Carousel PDP"
    }
  ]
}
{% endschema %}
