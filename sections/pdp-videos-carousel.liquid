<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<link rel="stylesheet" href="{{ 'pdp-videos-carousel.css' | asset_url }}">

<div class="section pdp-videos-carousel-container">
  <p class="section-heading">{{ section.settings.section_heading }}</p>
  <div class="pdp-specifications-container">
    {% for item in product.metafields.custom.product_specifications.value %}
      <div class="pdp-specifications-item">
        <p class="pdp-specifications-item-heading">{{ item.title }}</p>
        <p class="pdp-specifications-item-value">{{ item.content }}</p>
      </div>
    {% endfor %}
  </div>
  <div class="swiper pdp-videos-swiper">
    <div class="swiper-wrapper pdp-videos-carousel-wrapper">
      {% for video in product.metafields.custom.product_speciification_videos.value %}
        <div class="swiper-slide pdp-videos-carousel-video">
          {{ block.settings.video_url | video_tag: autoplay: true, loop: true, muted: true }}
          <p class="pdp-videos-carousel-content-heading">{{ block.settings.video_heading }}</p>
          <p class="pdp-videos-carousel-content-subheading">{{ block.settings.video_subheading }}</p>
        </div>
      {% endfor %}
    </div>

    <div class="testimonials-controls pdp-videos-controls">
      <button class="slider-nav-btn slider-nav-prev" id="pdp-videos-prev">
        <img
          src="https://cdn.shopify.com/s/files/1/0961/8086/3276/files/Group_1000001558_1.png?v=1772141969"
          alt="Previous"
          class="slider-arrow-icon slider-arrow-prev"
        >
      </button>

      <div class="swiper-pagination" id="pdp-videos-pagination"></div>

      <button class="slider-nav-btn slider-nav-next" id="pdp-videos-next">
        <img
          src="https://cdn.shopify.com/s/files/1/0961/8086/3276/files/Group_1000001558_1.png?v=1772141969"
          alt="Next"
          class="slider-arrow-icon"
        >
      </button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer="defer"></script>
<script>
  function initPdpVideosSwiper() {
    if (typeof Swiper === 'undefined') {
      setTimeout(initPdpVideosSwiper, 100);
      return;
    }

    const swiper = new Swiper('.pdp-videos-swiper', {
      slidesPerView: 'auto',
      spaceBetween: 20,

      navigation: {
        nextEl: '#pdp-videos-next',
        prevEl: '#pdp-videos-prev',
      },

      pagination: {
        el: '#pdp-videos-pagination',
        clickable: true,
        dynamicBullets: false,
        type: 'bullets',
      },

      grabCursor: true,
      touchRatio: 1.2,
      touchAngle: 45,
      simulateTouch: true,

      speed: 500,
      effect: 'slide',

      momentum: true,
      momentumBounce: true,
      momentumVelocityRatio: 0.85,
      momentumRatio: 1,
      freeMode: false,

      breakpoints: {
        0: {
          slidesPerView: 1,
          spaceBetween: 15,
        },
        768: {
          slidesPerView: 2,
          spaceBetween: 15,
        },
        1024: {
          slidesPerView: 3,
          spaceBetween: 20,
        },
      },

      keyboard: {
        enabled: true,
        onlyInViewport: true,
      },

      loop: false,
      rewind: true,
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPdpVideosSwiper);
  } else {
    initPdpVideosSwiper();
  }
</script>
{% schema %}
{
  "name": "Videos Carousel PDP",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "video",
          "id": "video_url",
          "label": "Video"
        },
        {
          "type": "text",
          "id": "video_heading",
          "label": "Video Heading"
        },
        {
          "type": "textarea",
          "id": "video_subheading",
          "label": "Video Subheading"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Videos Carousel PDP"
    }
  ]
}
{% endschema %}
